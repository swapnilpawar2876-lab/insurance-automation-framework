<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Insurance Automation Suite" verbose="1" parallel="none">

    <listeners>
        <listener class-name="utils.ExtentReportListener"/>
    </listeners>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.QuoteGenerationTest"/>
        </classes>
    </test>

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.QuoteGenerationTest"/>
            <class name="tests.PolicyCreationTest"/>
            <class name="tests.ClaimSubmissionTest"/>
        </classes>
    </test>

</suite>
